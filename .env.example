# Environment Variables Configuration
# Do not place actual secrets in this file. Copy this to .env and fill in the values.

# Supabase Configuration (Public, safe to expose to client)
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenRouter / AI Configuration (Private, MUST NEVER be exposed to client)
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
