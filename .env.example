# Environment Variables Configuration
# Do not place actual secrets in this file. Copy this to .env and fill in the values.

# Supabase Configuration (Public, safe to expose to client)
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenRouter / AI Configuration (Private, MUST NEVER be exposed to client)
# Get your free API key at https://openrouter.ai/keys
# REQUIRED: All AI features (chat, scholarship discovery) require this key.
# Only free models are used — no paid API charges will be incurred.
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
