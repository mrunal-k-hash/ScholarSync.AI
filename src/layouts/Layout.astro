---
import '../styles/global.css';
import { 
  Bell, 
  Menu, 
  X, 
  Sun, 
  Moon, 
  GraduationCap, 
  User, 
  LayoutDashboard, 
  Search, 
  FileText, 
  MessageSquare, 
  ShieldAlert, 
  LogOut,
  ChevronDown
} from '@lucide/astro';
import PrimerGrid from '../components/PrimerGrid.astro';
import InteractiveGrid from '../components/InteractiveGrid.astro';

interface Props {
  title?: string;
  activePage?: string;
}

const { title = 'ScholarSync AI', activePage = 'home' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="AI-powered ScholarSync and Eligibility Analyzer for students. Matches government & private schemes via OCR and intelligent profiles." />
    <title>{title}</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-white text-gray-900 min-h-screen flex flex-col font-sans transition-colors duration-300 antialiased selection:bg-black selection:text-white">
    <!-- Full-page interactive grid background -->
    <InteractiveGrid />
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-black text-white px-4 py-2 rounded-xl z-[100] outline-none focus-visible:ring-2 focus-visible:ring-black shadow-sm font-semibold text-sm">
      Skip to Content
    </a>

    <!-- Main Navigation Header -->
    <header class="sticky top-0 z-50 w-full bg-white/90 backdrop-blur-sm border-b border-gray-200 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo Section -->
          <div class="flex items-center">
            <a href="/" class="flex items-center gap-4 group">
              <span class="font-outfit font-black text-2xl tracking-tight text-black flex items-center">
                ScholarSync<span class="text-gray-500 font-medium tracking-normal"> AI</span>
              </span>
              <PrimerGrid 
                cols={3} 
                rows={2} 
                cellSize={24}
                cells={[
                  { row: 0, col: 1, color: 'bg-[#FFD13B]' },
                  { row: 1, col: 0, color: 'bg-[#FF6B2B]' },
                  { row: 1, col: 1, color: 'bg-[#3B82F6]' },
                  { row: 1, col: 2, color: 'bg-[#3B82F6]' }
                ]}
                className="hidden lg:grid shadow-sm"
              />
            </a>
          </div>

          <!-- Desktop Navigation -->
          <nav class="hidden md:flex space-x-1">
            <a href="/dashboard" class={`px-4 py-2 rounded-xl text-sm font-medium transition-colors outline-none focus-visible:ring-2 focus-visible:ring-black ${activePage === 'dashboard' ? 'bg-gray-100 text-black' : 'text-gray-600 hover:text-black hover:bg-gray-50'}`}>
              Dashboard
            </a>
            <a href="/eligibility" class={`px-4 py-2 rounded-xl text-sm font-medium transition-colors outline-none focus-visible:ring-2 focus-visible:ring-black ${activePage === 'eligibility' ? 'bg-gray-100 text-black' : 'text-gray-600 hover:text-black hover:bg-gray-50'}`}>
              Check Eligibility
            </a>
            <a href="/document-analyzer" class={`px-4 py-2 rounded-xl text-sm font-medium transition-colors outline-none focus-visible:ring-2 focus-visible:ring-black ${activePage === 'analyzer' ? 'bg-gray-100 text-black' : 'text-gray-600 hover:text-black hover:bg-gray-50'}`}>
              Doc Analyzer
            </a>
            <a href="/chat" class={`px-4 py-2 rounded-xl text-sm font-medium transition-colors outline-none focus-visible:ring-2 focus-visible:ring-black ${activePage === 'chat' ? 'bg-gray-100 text-black' : 'text-gray-600 hover:text-black hover:bg-gray-50'}`}>
              AI Chat
            </a>
          </nav>
 
           <!-- Topbar Actions -->
           <div class="flex items-center gap-2">
             <!-- Theme Toggle -->
             <button id="themeToggle" class="p-2 rounded-xl text-gray-500 hover:text-black hover:bg-gray-100 transition-colors outline-none focus-visible:ring-2 focus-visible:ring-black" aria-label="Toggle Theme">
               <Sun class="w-5 h-5 hidden dark:block text-black" aria-hidden="true" />
               <Moon class="w-5 h-5 block dark:hidden text-black" aria-hidden="true" />
             </button>
 
             <!-- Notifications Dropdown -->
             <div class="relative">
                <button id="notifyBtn" aria-label="Notifications" class="p-2 rounded-xl text-gray-500 hover:text-black hover:bg-gray-100 transition-colors outline-none focus-visible:ring-2 focus-visible:ring-black relative">
                  <Bell class="w-5 h-5" aria-hidden="true" />
                  <span id="notifBadge" class="hidden absolute top-1.5 right-1.5 min-w-[18px] h-[18px] rounded-full bg-red-500 border-2 border-white text-white text-[9px] font-bold flex items-center justify-center leading-none"></span>
                </button>
               
               <!-- Dropdown Panel -->
               <div id="notifyDropdown" class="hidden absolute right-0 mt-2 w-80 bg-white rounded-2xl shadow-lg p-4 z-50 border border-gray-200 max-h-96 overflow-y-auto">
                 <div class="flex justify-between items-center mb-3 pb-2 border-b border-gray-100">
                   <h4 class="font-outfit font-semibold text-sm text-gray-900">Notifications</h4>
                   <button id="clearNotifications" class="text-xs text-gray-500 hover:text-black font-medium outline-none px-1 py-0.5 rounded">Clear All</button>
                 </div>
                 <div class="space-y-3" id="notificationList">
                   <!-- Notification items will be loaded dynamically -->
                 </div>
               </div>
             </div>
 
             <!-- Auth Section -->
             <div class="relative" id="authSection">
               
               <!-- Logged Out View -->
               <div id="loggedOutView" class="hidden">
                 <a href="/login" class="px-4 py-2 bg-black text-white rounded-xl text-xs font-bold transition-colors hover:bg-gray-800 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-gray-400">
                   Sign In
                 </a>
               </div>

               <!-- Logged In View: Profile Dropdown -->
               <div id="loggedInView" class="relative hidden">
                 <button id="profileBtn" aria-label="Profile Menu" class="flex items-center gap-1.5 p-1 rounded-full md:pl-1 md:pr-3 md:py-1 bg-white hover:bg-gray-50 border border-gray-200 transition-colors text-left outline-none focus-visible:ring-2 focus-visible:ring-black">
                   <div class="w-8 h-8 rounded-full bg-black flex items-center justify-center text-white font-bold text-sm overflow-hidden border border-gray-200" id="navbarAvatarContainer">
                     <svg class="w-4 h-4" id="navbarDefaultAvatar" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                     <img id="navbarAvatarImage" src="" alt="Profile Avatar" class="w-full h-full object-cover hidden" />
                   </div>
                   <span class="hidden md:inline-block text-xs font-medium text-gray-900" id="navbarProfileName">User</span>
                   <svg class="w-3.5 h-3.5 text-gray-500 hidden md:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
                 </button>
                 
                 <!-- Dropdown Menu -->
                 <div id="profileDropdown" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg p-2 z-50 border border-gray-200">
                   <div class="px-3 py-2 mb-1 border-b border-gray-100 flex flex-col">
                     <span class="text-[11px] font-bold text-gray-900 truncate" id="dropdownName">User Name</span>
                     <span class="text-[10px] text-gray-500 truncate" id="dropdownEmail">user@example.com</span>
                   </div>
                   <a href="/profile" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs text-gray-700 hover:text-black hover:bg-gray-100 outline-none transition-colors">
                     <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                     Edit Profile
                   </a>
                   <a href="/dashboard" class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs text-gray-700 hover:text-black hover:bg-gray-100 outline-none transition-colors">
                     <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect><line x1="3" x2="21" y1="9" y2="9"></line><line x1="9" x2="9" y1="21" y2="9"></line></svg>
                     Dashboard
                   </a>
                   <hr class="border-gray-100 my-1" />
                   <button id="logoutBtn" class="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs text-red-600 hover:text-red-700 hover:bg-red-50 outline-none transition-colors text-left">
                     <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" x2="9" y1="12" y2="12"></line></svg>
                     Sign Out
                   </button>
                 </div>
               </div>
             </div>
 
             <!-- Mobile menu button -->
             <button id="mobileMenuBtn" aria-label="Toggle Mobile Menu" class="md:hidden p-2 rounded-xl text-gray-500 hover:text-black hover:bg-gray-100 transition-colors outline-none focus-visible:ring-2 focus-visible:ring-black">
               <Menu class="w-6 h-6 block" id="menuOpenIcon" aria-hidden="true" />
               <X class="w-6 h-6 hidden" id="menuCloseIcon" aria-hidden="true" />
             </button>
           </div>
         </div>
       </div>
 
       <!-- Mobile Menu -->
       <div id="mobileMenu" class="hidden md:hidden border-t border-gray-200 p-4 bg-white space-y-2 shadow-lg absolute w-full">
         <a href="/dashboard" class={`block px-4 py-2.5 rounded-xl text-sm font-medium outline-none focus-visible:ring-2 focus-visible:ring-black ${activePage === 'dashboard' ? 'bg-gray-100 text-black' : 'text-gray-600 hover:text-black hover:bg-gray-50'}`}>
           Dashboard
         </a>
         <a href="/eligibility" class={`block px-4 py-2.5 rounded-xl text-sm font-medium outline-none focus-visible:ring-2 focus-visible:ring-black ${activePage === 'eligibility' ? 'bg-gray-100 text-black' : 'text-gray-600 hover:text-black hover:bg-gray-50'}`}>
           Check Eligibility
         </a>
         <a href="/document-analyzer" class={`block px-4 py-2.5 rounded-xl text-sm font-medium outline-none focus-visible:ring-2 focus-visible:ring-black ${activePage === 'analyzer' ? 'bg-gray-100 text-black' : 'text-gray-600 hover:text-black hover:bg-gray-50'}`}>
           Doc Analyzer
         </a>
         <a href="/chat" class={`block px-4 py-2.5 rounded-xl text-sm font-medium outline-none focus-visible:ring-2 focus-visible:ring-black ${activePage === 'chat' ? 'bg-gray-100 text-black' : 'text-gray-600 hover:text-black hover:bg-gray-50'}`}>
           AI Chat
         </a>
       </div>
     </header>
 
     <!-- Main Content Slot -->
     <main id="main-content" class="flex-grow flex flex-col w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in relative z-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-auto border-t border-gray-200 py-8 bg-white/90 backdrop-blur-sm relative z-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-2">
          <div class="p-1.5 rounded-lg bg-black text-white">
            <GraduationCap class="w-4 h-4" />
          </div>
          <span class="font-outfit font-black text-sm tracking-tight text-gray-900">
            ScholarSync<span class="text-gray-500"> AI</span>
          </span>
        </div>
        <p class="text-xs text-gray-500">
          &copy; {new Date().getFullYear()} ScholarSync AI.
        </p>
        <div class="flex gap-4 text-xs text-gray-500">
          <a href="#" class="hover:text-black transition-colors">Privacy Policy</a>
          <a href="#" class="hover:text-black transition-colors">Terms of Service</a>
        </div>
      </div>
    </footer>

    <!-- Interactive Client Scripts for Theme, Dropdowns, Profile initialization -->
    <script>
      import { supabase } from '../utils/supabase';

      const loggedOutView = document.getElementById('loggedOutView');
      const loggedInView = document.getElementById('loggedInView');
      
      const navbarProfileName = document.getElementById('navbarProfileName');
      const dropdownName = document.getElementById('dropdownName');
      const dropdownEmail = document.getElementById('dropdownEmail');
      const navbarAvatarImage = document.getElementById('navbarAvatarImage') as HTMLImageElement;
      const navbarDefaultAvatar = document.getElementById('navbarDefaultAvatar');

      // Update UI based on auth state
      function updateAuthUI(session) {
        if (session) {
          loggedOutView?.classList.add('hidden');
          loggedInView?.classList.remove('hidden');
          
          const user = session.user;
          const fullName = user.user_metadata?.full_name || 'Student';
          const email = user.email || '';
          const avatarUrl = user.user_metadata?.avatar_url;

          if (navbarProfileName) navbarProfileName.textContent = fullName.split(' ')[0];
          if (dropdownName) dropdownName.textContent = fullName;
          if (dropdownEmail) dropdownEmail.textContent = email;

          if (avatarUrl && navbarAvatarImage && navbarDefaultAvatar) {
            navbarAvatarImage.src = avatarUrl;
            navbarAvatarImage.classList.remove('hidden');
            navbarDefaultAvatar.classList.add('hidden');
          }
        } else {
          loggedInView?.classList.add('hidden');
          loggedOutView?.classList.remove('hidden');
        }
      }

      // Initial check
      supabase.auth.getSession().then(({ data: { session } }) => {
        updateAuthUI(session);
      });

      // Listen for auth changes
      supabase.auth.onAuthStateChange((_event, session) => {
        updateAuthUI(session);
      });


      // Theme toggle logic
      const themeToggle = document.getElementById('themeToggle');
      const htmlEl = document.documentElement;
      
      // Load saved theme or system theme
      const savedTheme = localStorage.getItem('theme');
      if (savedTheme) {
        htmlEl.className = savedTheme;
      } else {
        htmlEl.className = 'dark';
      }

      themeToggle?.addEventListener('click', () => {
        if (htmlEl.classList.contains('dark')) {
          htmlEl.classList.remove('dark');
          htmlEl.classList.add('light');
          localStorage.setItem('theme', 'light');
        } else {
          htmlEl.classList.remove('light');
          htmlEl.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
      });

      // Dropdown handlers (Notification, Profile, Mobile Menu)
      const notifyBtn = document.getElementById('notifyBtn');
      const notifyDropdown = document.getElementById('notifyDropdown');
      const profileBtn = document.getElementById('profileBtn');
      const profileDropdown = document.getElementById('profileDropdown');
      const mobileMenuBtn = document.getElementById('mobileMenuBtn');
      const mobileMenu = document.getElementById('mobileMenu');
      const menuOpenIcon = document.getElementById('menuOpenIcon');
      const menuCloseIcon = document.getElementById('menuCloseIcon');

      // Toggle display
      const toggle = (el: Element | null) => el?.classList.toggle('hidden');
      const hideAll = () => {
        notifyDropdown?.classList.add('hidden');
        profileDropdown?.classList.add('hidden');
      };

      notifyBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        hideAll();
        toggle(notifyDropdown);
      });

      profileBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        hideAll();
        toggle(profileDropdown);
      });

      mobileMenuBtn?.addEventListener('click', () => {
        toggle(mobileMenu);
        menuOpenIcon?.classList.toggle('hidden');
        menuCloseIcon?.classList.toggle('hidden');
      });

      // Close dropdowns on document click
      document.addEventListener('click', () => {
        hideAll();
      });

      notifyDropdown?.addEventListener('click', (e) => e.stopPropagation());
      profileDropdown?.addEventListener('click', (e) => e.stopPropagation());

      // Logout handler
      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        localStorage.removeItem('scholarship_profile');
        localStorage.removeItem('saved_scholarships');
        localStorage.removeItem('uploaded_documents');
        window.location.replace('/');
      });

      // Notification clearing
      document.getElementById('clearNotifications')?.addEventListener('click', async () => {
        const { clearAllNotifications } = await import('../utils/notifications');
        await clearAllNotifications();
        renderNotifications();
        updateBadge(0);
      });

      // ── Notification Bell Integration ─────────────────────────────────
      async function renderNotifications() {
        const { getNotifications, timeAgo } = await import('../utils/notifications');
        const list = document.getElementById('notificationList');
        if (!list) return;

        const notifs = getNotifications();

        if (notifs.length === 0) {
          list.innerHTML = `
            <div class="text-center py-8 text-gray-400 text-xs font-medium flex flex-col items-center gap-2">
              <svg class="w-8 h-8 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              No notifications yet. Track a scholarship to get started.
            </div>
          `;
          return;
        }

        list.innerHTML = notifs.slice(0, 20).map(n => {
          const typeConfig = {
            tracking_started: { icon: '🔔', bg: 'bg-blue-50', border: 'border-blue-100', text: 'text-blue-700' },
            deadline_warning:  { icon: '📅', bg: 'bg-amber-50', border: 'border-amber-100', text: 'text-amber-700' },
            deadline_urgent:   { icon: '🚨', bg: 'bg-red-50', border: 'border-red-100', text: 'text-red-700' },
            deadline_passed:   { icon: '❌', bg: 'bg-gray-50', border: 'border-gray-200', text: 'text-gray-500' },
            info:              { icon: 'ℹ️', bg: 'bg-gray-50', border: 'border-gray-200', text: 'text-gray-600' },
          };
          const cfg = typeConfig[n.type] || typeConfig.info;

          return `
            <div class="p-3 rounded-xl ${cfg.bg} border ${cfg.border} ${n.is_read ? 'opacity-60' : ''} transition-opacity">
              <div class="flex items-start gap-2.5">
                <span class="text-sm mt-0.5 flex-shrink-0">${cfg.icon}</span>
                <div class="flex-grow min-w-0">
                  <p class="text-[11px] font-bold ${cfg.text} leading-snug">${n.title}</p>
                  <p class="text-[10px] text-gray-600 mt-0.5 leading-relaxed line-clamp-2">${n.message}</p>
                  <span class="text-[9px] text-gray-400 mt-1 block font-medium">${timeAgo(n.created_at)}</span>
                </div>
              </div>
            </div>
          `;
        }).join('');
      }

      function updateBadge(count: number) {
        const badge = document.getElementById('notifBadge');
        if (!badge) return;
        if (count > 0) {
          badge.textContent = count > 9 ? '9+' : count.toString();
          badge.classList.remove('hidden');
        } else {
          badge.classList.add('hidden');
        }
      }

      // Initial load
      async function initNotifications() {
        const { getUnreadCount } = await import('../utils/notifications');
        updateBadge(getUnreadCount());
        await renderNotifications();
      }
      initNotifications();

      // Listen for updates from dashboard or other pages
      window.addEventListener('notifications-updated', async () => {
        const { getUnreadCount } = await import('../utils/notifications');
        updateBadge(getUnreadCount());
        await renderNotifications();
      });
    </script>
  </body>
</html>
