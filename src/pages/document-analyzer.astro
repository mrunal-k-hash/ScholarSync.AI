---
import Layout from '../layouts/Layout.astro';
import { 
  FileText, 
  UploadCloud, 
  CheckCircle2, 
  XCircle, 
  HelpCircle,
  FileCheck,
  AlertTriangle,
  RotateCw
} from '@lucide/astro';
import PrimerGrid from '../components/PrimerGrid.astro';
---

<Layout title="Document Analyzer | ScholarSync AI" activePage="analyzer">
  <!-- Load Tesseract.js from CDN for browser OCR -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>

  <div class="max-w-5xl mx-auto space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-gray-200 pb-4 relative">
      <PrimerGrid 
        cols={5} rows={3} cellSize={18} 
        cells={[{ row: 2, col: 4, color: 'bg-[#3B82F6]' }, { row: 0, col: 3, color: 'bg-[#8B5CF6]' }]} 
        className="absolute right-0 top-0 opacity-20 hidden sm:grid" 
      />
      <div class="relative z-10">
        <h1 class="font-outfit text-3xl font-black text-gray-900">AI Document Analyzer</h1>
        <p class="text-xs text-gray-500 font-medium">Upload your educational and civil certificates. On-device OCR will extract data and check verification tags.</p>
      </div>
      <span class="px-2 py-0.5 rounded bg-blue-50 text-blue-700 text-[10px] font-bold border border-blue-200">
        On-Device Security (No Uploads)
      </span>
    </div>

    <!-- Main Content Grid -->
    <div class="grid lg:grid-cols-3 gap-8">
      
      <!-- Upload Panel (2 Cols) -->
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm">
          <h3 class="font-outfit font-bold text-sm text-gray-900 mb-4">Select Document Type</h3>
          
          <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-6">
            <button type="button" class="doc-tab p-3 rounded-xl bg-gray-50 border border-gray-200 text-center flex flex-col items-center gap-1.5 hover:bg-white hover:border-black hover:shadow-sm text-gray-700 font-medium transition-all text-xs outline-none focus-visible:ring-2 focus-visible:ring-black" data-doc="aadhaar">
              <span class="text-xs" aria-hidden="true">🆔</span>
              Aadhaar Card
            </button>
            <button type="button" class="doc-tab p-3 rounded-xl bg-gray-50 border border-gray-200 text-center flex flex-col items-center gap-1.5 hover:bg-white hover:border-black hover:shadow-sm text-gray-700 font-medium transition-all text-xs outline-none focus-visible:ring-2 focus-visible:ring-black" data-doc="income">
              <span class="text-xs" aria-hidden="true">💰</span>
              Income Cert
            </button>
            <button type="button" class="doc-tab p-3 rounded-xl bg-gray-50 border border-gray-200 text-center flex flex-col items-center gap-1.5 hover:bg-white hover:border-black hover:shadow-sm text-gray-700 font-medium transition-all text-xs outline-none focus-visible:ring-2 focus-visible:ring-black" data-doc="caste">
              <span class="text-xs" aria-hidden="true">📜</span>
              Caste Cert
            </button>
            <button type="button" class="doc-tab p-3 rounded-xl bg-gray-50 border border-gray-200 text-center flex flex-col items-center gap-1.5 hover:bg-white hover:border-black hover:shadow-sm text-gray-700 font-medium transition-all text-xs outline-none focus-visible:ring-2 focus-visible:ring-black" data-doc="marksheet">
              <span class="text-xs" aria-hidden="true">🎓</span>
              Marksheet
            </button>
            <button type="button" class="doc-tab p-3 rounded-xl bg-gray-50 border border-gray-200 text-center flex flex-col items-center gap-1.5 hover:bg-white hover:border-black hover:shadow-sm text-gray-700 font-medium transition-all text-xs outline-none focus-visible:ring-2 focus-visible:ring-black" data-doc="disability">
              <span class="text-xs" aria-hidden="true">♿</span>
              Disability Cert
            </button>
          </div>

          <!-- Drag and Drop Zone -->
          <div id="dropZone" tabindex="0" role="button" aria-label="Upload certificate" class="hidden border-2 border-dashed border-gray-300 hover:border-black hover:bg-gray-50 rounded-2xl p-8 text-center bg-white cursor-pointer transition-colors flex flex-col items-center gap-4 outline-none focus-visible:ring-2 focus-visible:ring-black">
            <input type="file" id="fileInput" name="certificateFile" accept="image/*" class="hidden" />
            <UploadCloud class="w-12 h-12 text-gray-400" aria-hidden="true" />
            <div>
              <p class="text-xs text-gray-900 font-bold" id="uploadTitle">Drag & Drop certificate here</p>
              <p class="text-[10px] text-gray-500 font-medium mt-1">Accepts PNG, JPG, JPEG (Max 5MB)</p>
            </div>
            <button type="button" class="px-4 py-2 rounded-xl bg-white border border-gray-200 text-[10px] font-bold text-gray-700 hover:bg-gray-50 outline-none focus-visible:ring-2 focus-visible:ring-black shadow-sm transition-colors">
              Browse Files
            </button>
          </div>
          
          <!-- OCR Progress Bar -->
          <div id="ocrProgressPanel" class="hidden p-4 rounded-xl bg-gray-50 border border-gray-200 space-y-3 mt-4" aria-live="polite">
            <div class="flex justify-between items-center text-[10px]">
              <span id="ocrStatusText" class="text-gray-900 font-bold flex items-center gap-1.5">
                <RotateCw class="w-3.5 h-3.5 animate-spin" aria-hidden="true" /> Initializing Tesseract engine…
              </span>
              <span id="ocrProgressPercent" class="text-gray-500 font-bold">0%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2 overflow-hidden">
              <div id="ocrProgressBar" class="bg-black h-full w-[10%] transition-all duration-300"></div>
            </div>
          </div>
        </div>

        <!-- OCR Raw text result -->
        <div id="ocrResultCard" class="hidden bg-white p-6 rounded-2xl border border-gray-200 shadow-sm space-y-4">
          <h4 class="font-outfit font-bold text-sm text-gray-900">Extracted Text Preview</h4>
          <div class="p-4 bg-gray-50 border border-gray-200 rounded-xl max-h-40 overflow-y-auto text-[10px] font-mono text-gray-600 leading-relaxed outline-none focus-visible:ring-1 focus-visible:ring-black" id="ocrExtractedText" tabindex="0">
            Extracted text…
          </div>
        </div>
      </div>

      <!-- Verification checklist / Profile mapping (1 Col) -->
      <div class="space-y-6">
        <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm flex flex-col">
          <h3 class="font-outfit font-bold text-sm text-gray-900 mb-4 border-b border-gray-100 pb-2 flex items-center gap-2">
            <FileCheck class="w-4.5 h-4.5 text-gray-700" />
            Verification Checklist
          </h3>
          
          <div class="space-y-4" id="checklistContainer">
            <!-- Items -->
            <div class="flex justify-between items-center p-3 rounded-xl bg-gray-50 border border-gray-200" id="chk-aadhaar">
              <div class="flex items-center gap-2">
                <span class="text-xs">🆔</span>
                <div>
                  <h4 class="text-[11px] font-bold text-gray-900">Aadhaar Card</h4>
                  <span class="text-[9px] text-gray-500 font-medium" id="aadhaarStatus">Missing verification</span>
                </div>
              </div>
              <span class="text-xs text-red-500">❌</span>
            </div>

            <div class="flex justify-between items-center p-3 rounded-xl bg-gray-50 border border-gray-200" id="chk-income">
              <div class="flex items-center gap-2">
                <span class="text-xs">💰</span>
                <div>
                  <h4 class="text-[11px] font-bold text-gray-900">Income Certificate</h4>
                  <span class="text-[9px] text-gray-500 font-medium" id="incomeStatus">Missing verification</span>
                </div>
              </div>
              <span class="text-xs text-red-500">❌</span>
            </div>

            <div class="flex justify-between items-center p-3 rounded-xl bg-gray-50 border border-gray-200" id="chk-caste">
              <div class="flex items-center gap-2">
                <span class="text-xs">📜</span>
                <div>
                  <h4 class="text-[11px] font-bold text-gray-900">Caste Certificate</h4>
                  <span class="text-[9px] text-gray-500 font-medium" id="casteStatus">Missing verification</span>
                </div>
              </div>
              <span class="text-xs text-red-500">❌</span>
            </div>

            <div class="flex justify-between items-center p-3 rounded-xl bg-gray-50 border border-gray-200" id="chk-marksheet">
              <div class="flex items-center gap-2">
                <span class="text-xs">🎓</span>
                <div>
                  <h4 class="text-[11px] font-bold text-gray-900">Marksheet Record</h4>
                  <span class="text-[9px] text-gray-500 font-medium" id="marksheetStatus">Missing verification</span>
                </div>
              </div>
              <span class="text-xs text-red-500">❌</span>
            </div>

            <div class="flex justify-between items-center p-3 rounded-xl bg-gray-50 border border-gray-200" id="chk-disability">
              <div class="flex items-center gap-2">
                <span class="text-xs">♿</span>
                <div>
                  <h4 class="text-[11px] font-bold text-gray-900">Disability Certificate</h4>
                  <span class="text-[9px] text-gray-500 font-medium" id="disabilityStatus">Missing verification</span>
                </div>
              </div>
              <span class="text-xs text-red-500">❌</span>
            </div>
          </div>

          <div class="border-t border-gray-200 pt-4 mt-4 space-y-3">
            <p class="text-[9px] text-gray-500 leading-relaxed font-medium">
              Verify your documents to achieve 100% profile authenticity. Once verified, your success predictions on the dashboard increase by 15%.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    import { supabase, getSessionId } from '../utils/supabase';
    declare const Tesseract: any;

    let activeDocType = "";
    let studentProfile: any = {};

    // Protect route
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (!session) {
        window.location.replace('/login');
      } else {
        updateChecklistUI();
      }
    });

    // Load Profile
    const profileStr = localStorage.getItem('scholarship_profile');
    if (profileStr) {
      try { studentProfile = JSON.parse(profileStr); } catch(e) {}
    }

    // Load saved checklist states
    let docsState = JSON.parse(localStorage.getItem('uploaded_documents') || '{}');

    // Update UI Checklist on mount
    function updateChecklistUI() {
      Object.keys(docsState).forEach(type => {
        const item = docsState[type];
        const row = document.getElementById(`chk-${type}`);
        const statusEl = document.getElementById(`${type}Status`);
        
        if (row && statusEl && item.verified) {
          statusEl.textContent = item.message || "Verified";
          statusEl.className = "text-[9px] text-green-700 font-bold";
          row.querySelector('span:last-child').textContent = "✅";
        }
      });
    }

    // Tab Selection
    document.querySelectorAll('.doc-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.doc-tab').forEach(t => t.classList.remove('border-black', 'bg-white', 'shadow-sm'));
        tab.classList.add('border-black', 'bg-white', 'shadow-sm');
        
        activeDocType = (tab as HTMLElement).dataset.doc;
        
        // Show Dropzone
        const dropZone = document.getElementById('dropZone');
        dropZone.classList.remove('hidden');
        document.getElementById('uploadTitle').textContent = `Upload / Drop your ${tab.textContent.trim()}`;
      });
    });

    // File input handlers
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');

    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') {
        e.preventDefault();
        fileInput.click();
      }
    });
    
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('border-black');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('border-black');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('border-black');
      const file = e.dataTransfer.files[0];
      if (file) handleFile(file);
    });

    fileInput.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      const file = target.files[0];
      if (file) handleFile(file);
    });

    function handleFile(file) {
      if (!file.type.startsWith('image/')) {
        alert("Please upload an image file (PNG, JPG, or JPEG).");
        return;
      }
      runOCR(file);
    }

    // Run Tesseract OCR client-side
    function runOCR(file) {
      const progressPanel = document.getElementById('ocrProgressPanel');
      const statusText = document.getElementById('ocrStatusText');
      const progressPercent = document.getElementById('ocrProgressPercent');
      const progressBar = document.getElementById('ocrProgressBar');
      const resultCard = document.getElementById('ocrResultCard');
      const textPreview = document.getElementById('ocrExtractedText');

      progressPanel.classList.remove('hidden');
      resultCard.classList.add('hidden');
      
      // Initialize Tesseract Worker
      Tesseract.recognize(
        file,
        'eng',
        {
          logger: m => {
            if (m.status === 'recognizing text') {
              const pct = Math.round(m.progress * 100);
              statusText.textContent = "Scanning text content…";
              progressPercent.textContent = `${pct}%`;
              progressBar.style.width = `${pct}%`;
            }
          }
        }
      ).then(({ data: { text } }) => {
        progressPanel.classList.add('hidden');
        resultCard.classList.remove('hidden');
        textPreview.textContent = text;
        
        analyzeExtractedText(text);
      }).catch(err => {
        console.error(err);
        statusText.textContent = "Scan failed!";
        progressPanel.classList.add('hidden');
      });
    }

    // Parse keywords in extracted text
    function analyzeExtractedText(text) {
      const lower = text.toLowerCase();
      let verified = false;
      let message = "Parsed successfully";

      if (activeDocType === 'aadhaar') {
        const hasNumbers = /\d{4}\s\d{4}\s\d{4}/.test(text) || /\d{12}/.test(text);
        if (hasNumbers) {
          verified = true;
          message = "Aadhaar Card Matched & Verified";
        } else {
          message = "No valid 12-digit Aadhaar number found.";
        }
      } else if (activeDocType === 'income') {
        // Look for numbers representing salary limits
        const numbers = lower.match(/\b\d{5,7}\b/g) || [];
        const incomeMatch = numbers.find(num => parseInt(num) < 2000000);
        if (incomeMatch) {
          verified = true;
          message = `Verified Income limit: ₹${parseInt(incomeMatch).toLocaleString()}`;
        } else {
          message = "Could not parse income limit. Re-upload.";
        }
      } else if (activeDocType === 'caste') {
        const cat = studentProfile.category || "OBC";
        if (lower.includes(cat.toLowerCase()) || lower.includes("backward") || lower.includes("caste") || lower.includes("tribe")) {
          verified = true;
          message = `Verified Category: ${cat}`;
        } else {
          message = `caste certificate doesn't match profile category: ${cat}`;
        }
      } else if (activeDocType === 'marksheet') {
        const marks = studentProfile.percentageOrCgpa || 75;
        const matchesMarks = lower.includes(String(Math.floor(marks))) || lower.includes("pass") || lower.includes("marks") || lower.includes("grade");
        if (matchesMarks) {
          verified = true;
          message = `Verified Marksheet: ${marks}%`;
        } else {
          message = "Marksheet matches profile";
        }
      } else if (activeDocType === 'disability') {
        if (lower.includes("disability") || lower.includes("handicap") || lower.includes("medical") || lower.includes("udid")) {
          verified = true;
          message = "Verified Disability Certificate";
        } else {
          message = "Disability details not found.";
        }
      }

      // Save upload state
      docsState[activeDocType] = { verified, message };
      localStorage.setItem('uploaded_documents', JSON.stringify(docsState));
      
      if (verified) {
        getSessionId().then(sessionId => {
          if (sessionId) {
            supabase.from('documents').insert({
              user_id: sessionId,
              doc_type: activeDocType,
              file_name: activeDocType + '_scan.png',
              file_size: 0
            }).then(({ error }) => {
              if (error) console.error("Error saving document to Supabase:", error);
            });
          }
        });
      }
      
      updateChecklistUI();
      
      if (verified) {
        alert(`Document verified! ${message}`);
      } else {
        alert(`OCR Scan Alert: ${message}. You can manually verify in profile if OCR misreads.`);
      }
    }
  </script>
</Layout>
