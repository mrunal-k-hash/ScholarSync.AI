---
import Layout from '../layouts/Layout.astro';
import { 
  FileCheck2, 
  XOctagon, 
  HelpCircle, 
  UserCheck, 
  RefreshCw, 
  Sparkles,
  ArrowRight,
  TrendingUp
} from '@lucide/astro';
import PrimerGrid from '../components/PrimerGrid.astro';
---

<Layout title="Eligibility Checker | ScholarSync AI" activePage="eligibility">
  <div class="max-w-5xl mx-auto space-y-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-gray-200 pb-4 gap-4 relative">
      <PrimerGrid 
        cols={6} rows={2} cellSize={20} 
        cells={[{ row: 0, col: 5, color: 'bg-[#FF6B2B]' }, { row: 1, col: 4, color: 'bg-[#10B981]' }]} 
        className="absolute right-1/4 top-0 opacity-30 hidden sm:grid" 
      />
      <div class="relative z-10">
        <h1 class="font-outfit text-3xl font-black text-gray-900">Eligibility Analyzer</h1>
        <p class="text-xs text-gray-500 font-medium">One-click evaluation of your qualifications across government and private programs.</p>
      </div>
      <button id="runCheckBtn" class="px-5 py-3 rounded-xl font-bold bg-black hover:bg-gray-800 text-white text-xs transition-colors flex items-center gap-2 shadow-sm outline-none focus-visible:ring-2 focus-visible:ring-black">
        <RefreshCw class="w-4 h-4" id="spinIcon" aria-hidden="true" />
        Analyze Eligibility
      </button>
    </div>
 
     <!-- Scanner Animation Overlay (shows when processing) -->
    <div id="scannerOverlay" class="hidden bg-white p-12 rounded-3xl border border-gray-200 shadow-sm text-center flex flex-col items-center justify-center gap-6 max-w-lg mx-auto py-20" aria-live="polite">
      <div class="relative w-20 h-20">
        <div class="absolute inset-0 rounded-full border-4 border-gray-100 border-t-black animate-spin"></div>
        <div class="absolute inset-2 rounded-full border-4 border-gray-100 border-b-gray-400 animate-spin" style="animation-duration: 1.5s;"></div>
        <div class="absolute inset-0 flex items-center justify-center text-2xl">🧠</div>
      </div>
      <div class="space-y-2">
        <h3 class="font-outfit font-bold text-lg text-gray-900">AI Engine Running</h3>
        <p class="text-xs text-gray-500 font-medium">Matching 40+ criteria points across category, income limits, and academic scores…</p>
      </div>
    </div>

    <!-- Main Results (Eligible vs Ineligible) -->
    <div id="resultsGrid" class="grid md:grid-cols-2 gap-8">
      
      <!-- Column 1: Eligible (Qualified) -->
      <div class="space-y-6">
        <div class="flex items-center justify-between border-b border-gray-200 pb-2 px-1">
          <h2 class="font-outfit text-lg font-bold text-green-700 flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-green-500 animate-pulse"></span>
            You Qualify For
          </h2>
          <span class="text-xs font-bold text-gray-500" id="eligibleCount">0 Schemes</span>
        </div>
        
        <div class="space-y-4" id="eligibleList">
          <!-- Populated dynamically -->
        </div>
      </div>

      <!-- Column 2: Ineligible (Criteria Mismatch) -->
      <div class="space-y-6">
        <div class="flex items-center justify-between border-b border-gray-200 pb-2 px-1">
          <h2 class="font-outfit text-lg font-bold text-red-600 flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse"></span>
            Mismatched Schemes
          </h2>
          <span class="text-xs font-bold text-gray-500" id="ineligibleCount">0 Schemes</span>
        </div>

        <div class="space-y-4" id="ineligibleList">
          <!-- Populated dynamically -->
        </div>
      </div>

    </div>
  </div>

  <script>
    import { supabase, getSessionId } from '../utils/supabase';

    let studentProfile: any = {};

    // Protect route
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (!session) {
        window.location.replace('/login');
      } else {
        // Trigger on load & button click
        const runBtn = document.getElementById('runCheckBtn');
        if (runBtn) runBtn.addEventListener('click', checkEligibility);
        
        loadProfile();
      }
    });

    // Load Profile
    async function loadProfile() {
      const sessionId = await getSessionId();
      if (sessionId) {
        const { data } = await supabase.from('profiles').select('*').eq('user_id', sessionId).single();
        if (data) {
          studentProfile = {
            name: data.name,
            age: data.age,
            gender: data.gender,
            state: data.state,
            category: data.category,
            familyIncome: data.family_income,
            educationLevel: data.education_level,
            currentCourse: data.current_course,
            percentageOrCgpa: data.percentage_or_cgpa,
            disabilityStatus: data.disability_status,
            minorityStatus: data.minority_status
          };
          localStorage.setItem('scholarship_profile', JSON.stringify(studentProfile));
        } else {
          loadLocal();
        }
      } else {
        loadLocal();
      }
      
      if (!studentProfile.name) {
        alert("Please configure your profile details first to run the eligibility check.");
        window.location.href = '/profile';
      } else {
        checkEligibility();
      }
    }
    
    function loadLocal() {
      const profileStr = localStorage.getItem('scholarship_profile');
      if (profileStr) {
        try { studentProfile = JSON.parse(profileStr); } catch(e) {}
      }
    }

    async function checkEligibility() {
      // Toggle animation
      const grid = document.getElementById('resultsGrid');
      const overlay = document.getElementById('scannerOverlay');
      const spinIcon = document.getElementById('spinIcon');
      
      grid.classList.add('opacity-30', 'pointer-events-none');
      overlay.classList.remove('hidden');
      spinIcon.classList.add('animate-spin');

      // Delay to simulate scanning
      await new Promise(r => setTimeout(r, 1200));

      try {
        const { data: sessionData } = await supabase.auth.getSession();
        const token = sessionData.session?.access_token;

        const res = await fetch('/api/match', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            ...(token ? { 'Authorization': `Bearer ${token}` } : {})
          },
          body: JSON.stringify({ profile: studentProfile })
        });
        const data = await res.json();
        
        renderLists(data.eligible || [], data.ineligible || []);
      } catch (error) {
        console.error("Match error:", error);
      } finally {
        grid.classList.remove('opacity-30', 'pointer-events-none');
        overlay.classList.add('hidden');
        spinIcon.classList.remove('animate-spin');
      }
    }

    function renderLists(eligible, ineligible) {
      const eligibleList = document.getElementById('eligibleList');
      const ineligibleList = document.getElementById('ineligibleList');

      // Update counters
      document.getElementById('eligibleCount').textContent = `${eligible.length} Schemes`;
      document.getElementById('ineligibleCount').textContent = `${ineligible.length} Schemes`;

      // Render Eligible
      if (eligible.length === 0) {
        eligibleList.innerHTML = `
          <div class="text-center py-16 bg-white rounded-2xl border border-gray-200 shadow-sm text-gray-500 text-xs font-medium">
            No matching qualifications found. Try raising grades or reviewing profile details.
          </div>
        `;
      } else {
        eligibleList.innerHTML = eligible.map(item => {
          const s = item.scholarship;
          return `
            <div class="bg-white p-5 rounded-2xl border border-gray-200 hover:border-green-300 shadow-sm transition-colors space-y-4">
              <div class="flex justify-between items-start gap-4">
                <div>
                  <span class="px-2 py-0.5 rounded bg-green-50 text-green-700 text-[8px] font-bold border border-green-200 uppercase tracking-wider">${s.type}</span>
                  <h3 class="font-outfit font-bold text-sm text-gray-900 mt-1.5">${s.name}</h3>
                  <p class="text-[9px] text-gray-500 font-medium">${s.sponsor}</p>
                </div>
                <span class="text-green-700 text-xs font-bold bg-green-50 px-2 py-0.5 rounded border border-green-200">${item.score}% Match</span>
              </div>
              
              <div class="p-3 bg-gray-50 rounded-xl text-[10px] text-gray-600 space-y-1.5 border border-gray-200">
                <span class="block text-[8px] text-gray-500 uppercase tracking-wider font-bold">Immediate Action Steps:</span>
                ${item.steps.map(step => `<p class="flex items-start gap-1.5 font-medium"><span class="text-green-600">•</span> ${step}</p>`).join('')}
              </div>

              <div class="flex justify-between items-center text-[10px] pt-1">
                <span class="text-black font-bold text-xs">${s.benefitAmount}</span>
                <a href="${s.officialLink}" target="_blank" class="flex items-center gap-1 text-black hover:text-gray-600 font-bold outline-none focus-visible:ring-2 focus-visible:ring-black rounded px-1 transition-colors">
                  Official Portal
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
              </div>
            </div>
          `;
        }).join('');
      }

      // Render Ineligible
      if (ineligible.length === 0) {
        ineligibleList.innerHTML = `
          <div class="text-center py-16 bg-white rounded-2xl border border-gray-200 shadow-sm text-gray-500 text-xs font-medium">
            Amazing! You match criteria for all available schemes.
          </div>
        `;
      } else {
        ineligibleList.innerHTML = ineligible.map(item => {
          const s = item.scholarship;
          return `
            <div class="bg-gray-50 p-5 rounded-2xl border border-gray-200 space-y-4">
              <div>
                <span class="px-2 py-0.5 rounded bg-red-50 text-red-700 text-[8px] font-bold border border-red-200 uppercase tracking-wider">${s.type}</span>
                <h3 class="font-outfit font-bold text-sm text-gray-700 mt-1.5">${s.name}</h3>
                <p class="text-[9px] text-gray-500 font-medium">${s.sponsor}</p>
              </div>

              <!-- Reason -->
              <div class="p-3 bg-red-50/50 rounded-xl text-[10px] text-red-700 space-y-1.5 border border-red-100">
                <span class="block text-[8px] text-red-800 uppercase tracking-wider font-bold">Mismatched Requirements:</span>
                ${item.reasons.map(reason => `<p class="flex items-start gap-1.5 font-medium"><span class="text-red-500">•</span> ${reason}</p>`).join('')}
              </div>

              <!-- Actions/Steps -->
              ${item.steps.length > 0 ? `
                <div class="p-3 bg-white rounded-xl text-[10px] text-gray-600 space-y-1.5 border border-gray-200 shadow-sm">
                  <span class="block text-[8px] text-gray-500 uppercase tracking-wider font-bold">How to become eligible:</span>
                  ${item.steps.map(step => `<p class="flex items-start gap-1.5 font-medium"><span class="text-black">•</span> ${step}</p>`).join('')}
                </div>
              ` : ''}
            </div>
          `;
        }).join('');
      }
    }
  </script>
</Layout>
