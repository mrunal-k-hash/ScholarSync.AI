  <!-- Interactive JavaScript for Match Simulator and FAQ Toggle -->
  <script is:inline>
    // FAQ Toggle
    function toggleFaq(btn) {
      const parent = btn.parentElement;
      const content = parent.querySelector('div');
      const icon = btn.querySelector('svg');
      
      const isOpen = !content.classList.contains('hidden');
      
      // Close all first
      document.querySelectorAll('.bg-gray-50 button').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
      });
      document.querySelectorAll('.bg-gray-50 button + div').forEach(div => {
        div.classList.add('hidden');
        div.style.maxHeight = '0px';
      });
      document.querySelectorAll('.bg-gray-50 button svg').forEach(svg => {
        svg.style.transform = 'rotate(0deg)';
      });

      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        content.classList.remove('hidden');
        content.style.maxHeight = '200px';
        icon.style.transform = 'rotate(180deg)';
      }
    }

    // Contact Form Alert
    document.getElementById('contactForm')?.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('Thank you for reaching out! Our team will contact you shortly.');
      e.target.reset();
    });

    // Match Simulator Data & Logic
    const SIMULATOR_SCHOLARSHIPS = [
      {
        name: "Reliance Foundation Undergraduate Scholarship",
        type: "Private",
        benefit: "Up to ₹2,00,000",
        minPercentage: 60,
        maxIncome: 1500000,
        categories: ["General", "OBC", "SC", "ST"]
      },
      {
        name: "Tata Capital Pankh Scholarship",
        type: "Need-Based",
        benefit: "Up to ₹50,000",
        minPercentage: 60,
        maxIncome: 400000,
        categories: ["General", "OBC", "SC", "ST"]
      },
      {
        name: "Post-Matric Scholarship for OBC Students",
        type: "State-Specific",
        benefit: "Full Tuition Fee Reimbursement",
        minPercentage: 50,
        maxIncome: 250000,
        categories: ["OBC"]
      },
      {
        name: "National Overseas Scholarship for SC/ST",
        type: "International",
        benefit: "Full Funding Abroad",
        minPercentage: 60,
        maxIncome: 800000,
        categories: ["SC", "ST"]
      },
      {
        name: "MOMA Merit-cum-Means Minority Scholarship",
        type: "Government",
        benefit: "₹20,000/year",
        minPercentage: 50,
        maxIncome: 250000,
        requiresMinority: true,
        categories: ["General", "OBC", "SC", "ST"]
      },
      {
        name: "NHFDC Scholarship for Disabled Students",
        type: "Government",
        benefit: "₹30,000/year",
        minPercentage: 50,
        maxIncome: 2000000,
        requiresDisability: true,
        categories: ["General", "OBC", "SC", "ST"]
      }
    ];

    const categoryInput = document.getElementById('demoCategory');
    const incomeInput = document.getElementById('demoIncome');
    const percentageInput = document.getElementById('demoPercentage');
    const disabilityInput = document.getElementById('demoDisability');
    const minorityInput = document.getElementById('demoMinority');
    
    const incomeVal = document.getElementById('incomeVal');
    const percentageVal = document.getElementById('percentageVal');
    const resultsContainer = document.getElementById('demoResults');
    const countBadge = document.getElementById('matchCount');

    function updateSimulator() {
      const category = categoryInput.value;
      const income = parseInt(incomeInput.value);
      const percentage = parseInt(percentageInput.value);
      const requiresDisability = disabilityInput.checked;
      const requiresMinority = minorityInput.checked;

      // Update Labels
      incomeVal.textContent = "₹" + income.toLocaleString('en-IN');
      percentageVal.textContent = percentage + "%";

      // Filter logic
      const matches = SIMULATOR_SCHOLARSHIPS.filter(s => {
        if (!s.categories.includes(category)) return false;
        if (s.maxIncome && income > s.maxIncome) return false;
        if (s.minPercentage && percentage < s.minPercentage) return false;
        if (s.requiresDisability && !requiresDisability) return false;
        if (s.requiresMinority && !requiresMinority) return false;
        return true;
      });

      // Update Badge
      countBadge.textContent = matches.length + (matches.length === 1 ? " Match" : " Matches");

      // Render items
      if (matches.length === 0) {
        resultsContainer.innerHTML = `
          <div class="text-center py-12 text-gray-500 text-xs font-medium">
            No scholarships found for this criteria. Try sliding down the income or category inputs.
          </div>
        `;
        return;
      }

      resultsContainer.innerHTML = matches.map(s => `
        <div class="flex items-center justify-between p-4 rounded-xl bg-gray-50 border border-gray-200 hover:border-gray-300 transition-all">
          <div class="space-y-1">
            <span class="px-2 py-0.5 rounded-full bg-white border border-gray-200 text-gray-600 text-[9px] font-bold uppercase tracking-wider">${s.type}</span>
            <h4 class="text-xs font-bold text-gray-900 mt-1">${s.name}</h4>
            <p class="text-[10px] text-gray-500">Award: <span class="text-black font-semibold">${s.benefit}</span></p>
          </div>
          <a href="/dashboard" class="px-3 py-1.5 rounded-lg bg-black text-white text-[10px] font-bold hover:bg-gray-800 transition-colors">
            View Details
          </a>
        </div>
      `).join('');
    }

    // Bind event listeners
    categoryInput?.addEventListener('change', updateSimulator);
    incomeInput?.addEventListener('input', updateSimulator);
    percentageInput?.addEventListener('input', updateSimulator);
    disabilityInput?.addEventListener('change', updateSimulator);
    minorityInput?.addEventListener('change', updateSimulator);

    // Initial Trigger
    updateSimulator();
  </script>

  <script>
    import { supabase } from '../utils/supabase';
    supabase.auth.getSession().then(({ data: { session } }) => {
      const ctaBtn = document.getElementById('ctaBtnMain') as HTMLAnchorElement;
      if (session && ctaBtn) {
        ctaBtn.innerHTML = `Go to Dashboard <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>`;
        ctaBtn.href = '/dashboard';
      } else if (ctaBtn) {
        ctaBtn.href = '/login';
      }
    });
  </script>
