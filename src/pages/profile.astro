---
import Layout from '../layouts/Layout.astro';
import { 
  User, 
  GraduationCap, 
  Wallet, 
  Sparkles, 
  Save, 
  AlertCircle
} from '@lucide/astro';
import PrimerGrid from '../components/PrimerGrid.astro';
---

<Layout title="My Student Profile | ScholarSync AI" activePage="profile">
  <div class="max-w-4xl mx-auto space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-gray-200 pb-4 relative">
      <PrimerGrid 
        cols={5} rows={2} cellSize={20} 
        cells={[{ row: 1, col: 4, color: 'bg-[#FFD13B]' }, { row: 0, col: 3, color: 'bg-[#3B82F6]' }]} 
        className="absolute right-0 top-0 opacity-30 hidden sm:grid" 
      />
      <div class="relative z-10">
        <h1 class="font-outfit text-3xl font-black text-gray-900">Student Profile</h1>
        <p class="text-xs text-gray-500 font-medium">Complete your profile details to match with targeted scholarships.</p>
      </div>
      <div class="flex items-center gap-2 text-[10px] text-gray-500 font-medium">
        <span class="w-2.5 h-2.5 rounded-full bg-blue-500 animate-pulse"></span>
        Matches update automatically
      </div>
    </div>

    <!-- Main Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Sidebar Quick Tips -->
      <div class="space-y-6">
        <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm">
          <h3 class="font-outfit font-bold text-sm text-gray-900 mb-3 flex items-center gap-2">
            <Sparkles class="w-4.5 h-4.5 text-gray-500" />
            Profile Quality
          </h3>
          <div class="relative w-full bg-gray-100 rounded-full h-2.5 mb-2 overflow-hidden border border-gray-200">
            <div id="profileProgress" class="bg-black h-full rounded-full transition-all duration-500" style="width: 0%;"></div>
          </div>
          <span class="text-[10px] text-gray-600 font-medium block" id="progressText">0% Completed</span>
          <p class="text-[10px] text-gray-500 mt-3 leading-relaxed font-medium">
            Ensure your marks and annual family income are accurate. Sponsors strictly audit these values during verification.
          </p>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm space-y-4">
          <h4 class="font-outfit font-bold text-xs text-gray-900">Why Caste & minority matter?</h4>
          <p class="text-[10px] text-gray-600 leading-relaxed font-medium">
            Government post-matric and overseas schemes are budgeted according to community reservations (OBC, SC, ST) and minority status.
          </p>
          <hr class="border-gray-200" />
          <h4 class="font-outfit font-bold text-xs text-gray-900">Income Cap Policies</h4>
          <p class="text-[10px] text-gray-600 leading-relaxed font-medium">
            Most need-based grants cap maximum income at ₹2.5L, ₹4.5L, or ₹8L.
          </p>
        </div>
      </div>

      <!-- Form (2 cols) -->
      <div class="md:col-span-2">
        <form id="profileForm" class="space-y-6">
          <!-- Card 1: Personal Info -->
          <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm space-y-4">
            <h3 class="font-outfit font-bold text-sm text-gray-900 flex items-center gap-2 border-b border-gray-100 pb-2">
              <User class="w-4 h-4 text-gray-500" />
              1. Personal Demographics
            </h3>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="profName" class="block text-[10px] font-bold tracking-wider text-gray-500 uppercase mb-1">Full Name</label>
                <input type="text" id="profName" name="name" required autocomplete="name" class="w-full px-3 py-2.5 text-xs rounded-xl bg-gray-50 border border-gray-200 text-gray-900 outline-none focus-visible:ring-2 focus-visible:ring-black transition-colors" placeholder="Arjun Sharma" />
              </div>
              <div>
                <label for="profAge" class="block text-[10px] font-bold tracking-wider text-gray-500 uppercase mb-1">Age</label>
                <input type="number" id="profAge" name="age" min="5" max="99" required class="w-full px-3 py-2.5 text-xs rounded-xl bg-gray-50 border border-gray-200 text-gray-900 outline-none focus-visible:ring-2 focus-visible:ring-black transition-colors" placeholder="20" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="profGender" class="block text-[10px] font-bold tracking-wider text-gray-500 uppercase mb-1">Gender</label>
                <select id="profGender" name="gender" class="w-full px-3 py-2.5 text-xs rounded-xl bg-gray-50 border border-gray-200 text-gray-900 outline-none focus-visible:ring-2 focus-visible:ring-black transition-colors">
                  <option value="Male">Male</option>
                  <option value="Female">Female</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div>
                <label for="profState" class="block text-[10px] font-bold tracking-wider text-gray-500 uppercase mb-1">State of Residence</label>
                <select id="profState" name="state" class="w-full px-3 py-2.5 text-xs rounded-xl bg-gray-50 border border-gray-200 text-gray-900 outline-none focus-visible:ring-2 focus-visible:ring-black transition-colors">
                  <option value="Maharashtra">Maharashtra</option>
                  <option value="Delhi">Delhi</option>
                  <option value="Karnataka">Karnataka</option>
                  <option value="Tamil Nadu">Tamil Nadu</option>
                  <option value="Uttar Pradesh">Uttar Pradesh</option>
                  <option value="Gujarat">Gujarat</option>
                  <option value="West Bengal">West Bengal</option>
                  <option value="Rajasthan">Rajasthan</option>
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="profCategory" class="block text-[10px] font-bold tracking-wider text-gray-500 uppercase mb-1">Caste Category</label>
                <select id="profCategory" name="category" class="w-full px-3 py-2.5 text-xs rounded-xl bg-gray-50 border border-gray-200 text-gray-900 outline-none focus-visible:ring-2 focus-visible:ring-black transition-colors">
                  <option value="General">General (Unreserved)</option>
                  <option value="OBC">OBC (Other Backward Classes)</option>
                  <option value="SC">SC (Scheduled Caste)</option>
                  <option value="ST">ST (Scheduled Tribe)</option>
                </select>
              </div>
              <div class="flex items-center h-full pt-4">
                <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer font-medium">
                  <input type="checkbox" id="profMinority" name="minorityStatus" class="rounded accent-black outline-none focus-visible:ring-2 focus-visible:ring-black" />
                  Belong to Minority Community?
                </label>
              </div>
            </div>
          </div>

          <!-- Card 2: Academics -->
          <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm space-y-4">
            <h3 class="font-outfit font-bold text-sm text-gray-900 flex items-center gap-2 border-b border-gray-100 pb-2">
              <GraduationCap class="w-4.5 h-4.5 text-gray-500" />
              2. Academic Information
            </h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="profEdu" class="block text-[10px] font-bold tracking-wider text-gray-500 uppercase mb-1">Education Level</label>
                <select id="profEdu" name="educationLevel" class="w-full px-3 py-2.5 text-xs rounded-xl bg-gray-50 border border-gray-200 text-gray-900 outline-none focus-visible:ring-2 focus-visible:ring-black transition-colors">
                  <option value="School">School Education</option>
                  <option value="Diploma">Diploma Program</option>
                  <option value="Undergraduate">Undergraduate Degree</option>
                  <option value="Postgraduate">Postgraduate Degree</option>
                  <option value="PhD">PhD / Doctoral</option>
                </select>
              </div>
              <div>
                <label for="profCourse" class="block text-[10px] font-bold tracking-wider text-gray-500 uppercase mb-1">Current Course</label>
                <input type="text" id="profCourse" name="currentCourse" required class="w-full px-3 py-2.5 text-xs rounded-xl bg-gray-50 border border-gray-200 text-gray-900 outline-none focus-visible:ring-2 focus-visible:ring-black transition-colors" placeholder="e.g. B.Tech Computer Science" />
              </div>
            </div>

            <div>
              <label for="profMarks" class="block text-[10px] font-bold tracking-wider text-gray-500 uppercase mb-1">Academic Score (Percentage % / CGPA out of 10)</label>
              <input type="number" step="0.01" min="0" max="100" id="profMarks" name="percentageOrCgpa" required class="w-full px-3 py-2.5 text-xs rounded-xl bg-gray-50 border border-gray-200 text-gray-900 outline-none focus-visible:ring-2 focus-visible:ring-black transition-colors" placeholder="e.g. 85%" />
              <p class="text-[9px] text-gray-500 mt-1 font-medium">If your system uses a 10-point scale (CGPA), enter it directly (e.g., 8.5). We will auto-normalize it.</p>
            </div>
          </div>

          <!-- Card 3: Financial & Disability -->
          <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm space-y-4">
            <h3 class="font-outfit font-bold text-sm text-gray-900 flex items-center gap-2 border-b border-gray-100 pb-2">
              <Wallet class="w-4 h-4 text-gray-500" aria-hidden="true" />
              3. Finance & Special Status
            </h3>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="profIncome" class="block text-[10px] font-bold tracking-wider text-gray-500 uppercase mb-1">Annual Family Income (₹)</label>
                <input type="number" id="profIncome" name="familyIncome" min="0" required class="w-full px-3 py-2.5 text-xs rounded-xl bg-gray-50 border border-gray-200 text-gray-900 outline-none focus-visible:ring-2 focus-visible:ring-black transition-colors" placeholder="e.g. 250000" />
              </div>
              <div class="flex items-center h-full pt-4">
                <label class="flex items-center gap-2 text-xs text-gray-700 cursor-pointer font-medium">
                  <input type="checkbox" id="profDisability" name="disabilityStatus" class="rounded accent-black outline-none focus-visible:ring-2 focus-visible:ring-black" />
                  Have Physical Disability (40%+)?
                </label>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex items-center gap-4">
            <button type="submit" class="flex-grow sm:flex-grow-0 px-6 py-3 rounded-xl font-bold bg-black hover:bg-gray-800 text-white shadow-sm transition-colors outline-none focus-visible:ring-2 focus-visible:ring-black flex items-center justify-center gap-2">
              <Save class="w-4.5 h-4.5" aria-hidden="true" />
              Save Changes
            </button>
            <a href="/dashboard" class="px-6 py-3 rounded-xl border border-gray-200 hover:bg-gray-50 transition-colors text-xs font-bold text-gray-700 flex items-center justify-center outline-none focus-visible:ring-2 focus-visible:ring-black">
              Back to Dashboard
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    import { supabase, getSessionId } from '../utils/supabase';

    // Elements
    const form = document.getElementById('profileForm') as HTMLFormElement;
    const progressBar = document.getElementById('profileProgress');
    const progressText = document.getElementById('progressText');

    // Protect route
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (!session) {
        window.location.replace('/login');
      } else {
        loadProfile();
      }
    });

    // Load Existing Profile
    async function loadProfile() {
      const sessionId = await getSessionId();
      let data: any = null;
      
      // Try to fetch from Supabase first
      if (sessionId) {
        const { data: sbData, error } = await supabase
          .from('profiles')
          .select('*')
          .eq('user_id', sessionId)
          .single();
          
        if (sbData && !error) {
          data = {
            name: sbData.name,
            age: sbData.age,
            gender: sbData.gender,
            state: sbData.state,
            category: sbData.category,
            familyIncome: sbData.family_income,
            educationLevel: sbData.education_level,
            currentCourse: sbData.current_course,
            percentageOrCgpa: sbData.percentage_or_cgpa,
            disabilityStatus: sbData.disability_status,
            minorityStatus: sbData.minority_status
          };
          // Sync to local
          localStorage.setItem('scholarship_profile', JSON.stringify(data));
        }
      }
      
      // Fallback to localStorage if Supabase had nothing
      if (!data) {
        const stored = localStorage.getItem('scholarship_profile');
        if (stored) {
          try { data = JSON.parse(stored); } catch(e) {}
        }
      }

      // Populate form fields (empty if no data at all)
      if (data) {
        (document.getElementById('profName') as HTMLInputElement).value = data.name || '';
        (document.getElementById('profAge') as HTMLInputElement).value = data.age || '';
        (document.getElementById('profGender') as HTMLSelectElement).value = data.gender || 'Male';
        (document.getElementById('profState') as HTMLSelectElement).value = data.state || 'Maharashtra';
        (document.getElementById('profCategory') as HTMLSelectElement).value = data.category || 'General';
        (document.getElementById('profEdu') as HTMLSelectElement).value = data.educationLevel || 'Undergraduate';
        (document.getElementById('profCourse') as HTMLInputElement).value = data.currentCourse || '';
        (document.getElementById('profMarks') as HTMLInputElement).value = data.percentageOrCgpa || '';
        (document.getElementById('profIncome') as HTMLInputElement).value = data.familyIncome || '';
        (document.getElementById('profMinority') as HTMLInputElement).checked = data.minorityStatus || false;
        (document.getElementById('profDisability') as HTMLInputElement).checked = data.disabilityStatus || false;
      }

      calculateCompleteness();
    }

    // Calculate Completion Percentage
    function calculateCompleteness() {
      const fields = [
        document.getElementById('profName').value,
        document.getElementById('profAge').value,
        document.getElementById('profCourse').value,
        document.getElementById('profMarks').value,
        document.getElementById('profIncome').value
      ];
      
      let filled = 0;
      fields.forEach(f => { if(f && String(f).trim() !== "") filled++; });
      
      // Calculate percentage out of 100
      const completion = Math.round((filled / fields.length) * 100);
      progressBar.style.width = completion + "%";
      progressText.textContent = completion + "% Completed";
    }

    // Bind Change listeners
    ['profName', 'profAge', 'profCourse', 'profMarks', 'profIncome'].forEach(id => {
      document.getElementById(id).addEventListener('input', calculateCompleteness);
    });

    // Form Submit
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const sessionId = await getSessionId();
      
      const profile = {
        name: (document.getElementById('profName') as HTMLInputElement).value,
        age: parseInt((document.getElementById('profAge') as HTMLInputElement).value),
        gender: (document.getElementById('profGender') as HTMLInputElement).value,
        state: (document.getElementById('profState') as HTMLInputElement).value,
        category: (document.getElementById('profCategory') as HTMLInputElement).value,
        educationLevel: (document.getElementById('profEdu') as HTMLInputElement).value,
        currentCourse: (document.getElementById('profCourse') as HTMLInputElement).value,
        percentageOrCgpa: parseFloat((document.getElementById('profMarks') as HTMLInputElement).value),
        familyIncome: parseInt((document.getElementById('profIncome') as HTMLInputElement).value),
        minorityStatus: (document.getElementById('profMinority') as HTMLInputElement).checked,
        disabilityStatus: (document.getElementById('profDisability') as HTMLInputElement).checked
      };

      // 1. Sync to local storage
      localStorage.setItem('scholarship_profile', JSON.stringify(profile));
      
      // 2. Sync to Supabase cloud
      if (sessionId) {
        const { error } = await supabase.from('profiles').upsert({
          user_id: sessionId,
          name: profile.name,
          age: profile.age,
          gender: profile.gender,
          state: profile.state,
          category: profile.category,
          family_income: profile.familyIncome,
          education_level: profile.educationLevel,
          current_course: profile.currentCourse,
          percentage_or_cgpa: profile.percentageOrCgpa,
          disability_status: profile.disabilityStatus,
          minority_status: profile.minorityStatus
        });
        
        if (error) {
          console.error('Supabase Save Error:', error);
          alert('Warning: Profile saved locally but cloud sync failed. Error: ' + error.message);
        } else {
          alert('Success! Your profile details have been securely saved to the cloud.');
        }
      } else {
        alert('Profile saved locally. Sign in to sync to the cloud.');
      }

      window.location.href = '/dashboard';
    });
  </script>
</Layout>
